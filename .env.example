# Copy to .env (gitignored) and fill in. Do NOT commit real values.
REPLYFLOW_BASE_TOKEN=your-feishu-base-token
REPLYFLOW_TABLE_ID=your-feishu-table-id
REPLYFLOW_FROM_ADDRESS=you@example.com
# Your display name in the Feishu "负责人" (owner) field. The app only shows/counts
# rows you own. Leave empty to disable owner-filtering (single-user / dedicated table).
REPLYFLOW_OWNER=Your Name
REPLYFLOW_INTERNAL_DOMAINS=@your-company.com,@your-product.com
# Optional: the "上线记录" (go-live) table id, for the 已上线 group / 上线 flow.
REPLYFLOW_GOLIVE_TABLE_ID=
REPLYFLOW_BLOOME_IMG=/absolute/path/to/promo-image.png
REPLYFLOW_INBOX_LIMIT=200
