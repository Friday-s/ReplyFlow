# Copy to .env (gitignored) and fill in. Do NOT commit real values.
REPLYFLOW_BASE_TOKEN=your-feishu-base-token
REPLYFLOW_TABLE_ID=your-feishu-table-id
REPLYFLOW_FROM_ADDRESS=you@example.com
# Your display name in the Feishu "负责人" (owner) field. The app only shows/counts
# rows you own. Leave empty to disable owner-filtering (single-user / dedicated table).
REPLYFLOW_OWNER=Your Name
REPLYFLOW_INTERNAL_DOMAINS=@your-company.com,@your-product.com
# Optional: the "上线记录" (go-live) table id, for the 已上线 group / 上线 flow.
REPLYFLOW_GOLIVE_TABLE_ID=
REPLYFLOW_BLOOME_IMG=/absolute/path/to/promo-image.png
REPLYFLOW_INBOX_LIMIT=200
# Optional second data source: a Feishu table that already pairs an email column with a
# profile URL. When both are set, its active rows are merged into the inbox-matching set.
# The table is expected to have columns: 联系方式 (email), X账号 (profile URL),
# 当前状态 (status), 备注 (note). Leave empty to disable.
REPLYFLOW_X_BASE_TOKEN=
REPLYFLOW_X_TABLE_ID=
# Optional canonical links injected into collab-stage AI reply prompts (omitted if empty):
# product intro / brief, and a payment-info collection form.
REPLYFLOW_BRIEF_URL=
REPLYFLOW_PAYMENT_FORM_URL=
# Optional: the invoice header / bill-to entity name shown in the payment guard banner.
# Defaults to a generic placeholder when unset.
REPLYFLOW_INVOICE_ENTITY=
